# Comma-separated list of health URLs to ping.
TARGET_URLS=https://spotify-resonance.onrender.com/health

# Base interval between pings (seconds). Keep below Render's sleep timeout
# (15 min = 900s). 600 = 10 min is a safe default.
PING_INTERVAL_SECONDS=600

# APScheduler adds a uniform random delay in [0, JITTER_SECONDS] to each
# trigger to prevent lockstep patterns. 120 = ±2 min spread.
JITTER_SECONDS=120

# Per-attempt HTTP timeout (seconds).
REQUEST_TIMEOUT=15.0

# Retries per ping cycle before marking as failure.
MAX_RETRIES=3

# Circuit breaker: open after this many consecutive failures.
CB_FAILURE_THRESHOLD=3

# Circuit breaker: seconds before attempting recovery (OPEN → HALF_OPEN).
CB_RECOVERY_SECONDS=300

# Optional: HTTP POST webhook URL for sustained-downtime alerts.
# Works with Slack incoming webhooks or any generic endpoint.
# Leave blank to disable.
ALERT_WEBHOOK_URL=

# Fire alert after this many consecutive failures (must also be >= CB_FAILURE_THRESHOLD).
ALERT_AFTER_FAILURES=3

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
